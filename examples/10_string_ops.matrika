# স্ট্রিং অপারেশন
ধরি প্রথম_নাম = "আব্দুল"
ধরি শেষ_নাম = "করিম"
ধরি পূর্ণ_নাম = প্রথম_নাম + " " + শেষ_নাম

বল("পূর্ণ নাম: " + পূর্ণ_নাম)

# সংখ্যা থেকে স্ট্রিং কনভার্সন
ধরি বছর = 2024
ধরি বার্তা = "বর্তমান বছর " + বছর + " সাল।"
বল(বার্তা)

# বুলিয়ান অপারেশন
ধরি পাস = সত্য
যদি পাস {
    বল("পরীক্ষায় উত্তীর্ণ!")
} নাহলে {
    বল("পরীক্ষায় অনুত্তীর্ণ।")
}
