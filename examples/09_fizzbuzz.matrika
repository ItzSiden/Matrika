# ফিজবাজ - ক্লাসিক প্রোগ্রামিং সমস্যা
# ৩ এর গুণিতক -> "ফিজ"
# ৫ এর গুণিতক -> "বাজ"
# উভয়ের গুণিতক -> "ফিজবাজ"
ধরি i = 1
যতক্ষণ i <= 20 {
    যদি (i % 15) == 0 {
        বল("ফিজবাজ")
    } নাহলে {
        যদি (i % 3) == 0 {
            বল("ফিজ")
        } নাহলে {
            যদি (i % 5) == 0 {
                বল("বাজ")
            } নাহলে {
                বল(i)
            }
        }
    }
    ধরি i = i + 1
}
