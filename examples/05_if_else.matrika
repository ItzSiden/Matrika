# শর্ত - যদি / নাহলে
ধরি নম্বর = 75

যদি নম্বর >= 80 {
    বল("ফলাফল: A")
} নাহলে {
    যদি নম্বর >= 70 {
        বল("ফলাফল: B")
    } নাহলে {
        যদি নম্বর >= 60 {
            বল("ফলাফল: C")
        } নাহলে {
            বল("ফলাফল: F")
        }
    }
}

# জোড়/বিজোড় পরীক্ষা
ধরি সংখ্যা = 42
যদি (সংখ্যা % 2) == 0 {
    বল(সংখ্যা + " জোড় সংখ্যা")
} নাহলে {
    বল(সংখ্যা + " বিজোড় সংখ্যা")
}
